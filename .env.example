# .env.example
# ─────────────────────────────────────────────
# Copy this to .env for local development.
# In production these values come from the K8s Secret
# 'api-gateway-secrets' injected via secretRef in Helm.
#
# NEVER commit .env — it's in .gitignore
# ─────────────────────────────────────────────

# PostgreSQL — OCI ADB connection string
DATABASE_URL=postgresql://**********:**********@adb.us-ashburn-1.oraclecloud.com:1522/**********?sslmode=require

# Redis — K3s internal service name (use localhost for local dev)
REDIS_URL=redis://localhost:6379

# Auth Service — where to fetch the JWT public key at startup
AUTH_SERVICE_URL=http://localhost:5000

# Feature Flag Service — for evaluateFlag() calls in canary routing
FLAG_SERVICE_URL=http://localhost:4000

# AWS SNS — circuit breaker trip notifications
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:circuit-trips

# OpenTelemetry — Grafana Cloud Tempo
# Leave empty to disable tracing in local dev
OTLP_ENDPOINT=
OTLP_USERNAME=
OTLP_PASSWORD=

# Service name shown in Grafana traces
SERVICE_NAME=api-gateway

# Port
PORT=3000

# Environment label for SNS messages
ENVIRONMENT=development
